  "exploreTitleElegantSnakeTattoo": "Tatuaggio serpente elegante",
  "@exploreTitleElegantSnakeTattoo": { "description": "Home: Explore item title - Elegant snake tattoo" },
  "explorePromptElegantSnakeTattoo": "Tatuaggio serpente aggressivo ultra dettagliato in bianco e nero, bocca aperta con zanne lunghe e lingua biforcuta, corpo arrotolato fluente, squame dettagliate linea fine, ombreggiatura nera profonda, forte contrasto, profondità realistica, spazio negativo pulito, incisione tradizionale × realismo moderno, contorni taglienti, inchiostro monocromatico, nessuno sfondo, flash tatuaggio professionale, pronto per avambraccio o manica.",
  "@explorePromptElegantSnakeTattoo": { "description": "Home: Explore item prompt - Elegant snake tattoo" },

  "exploreTitleFeatherAndBirdsInFlight": "Piuma e uccelli in volo",
  "@exploreTitleFeatherAndBirdsInFlight": { "description": "Home: Explore item title - Feather and birds in flight" },
  "explorePromptFeatherAndBirdsInFlight": "Tatuaggio piuma ultra dettagliato in bianco e nero, piuma realistica elegante con lavoro linee fine, barbe simmetriche e spina affilata, ombreggiatura gradiente dotwork liscia, stile fineline premium minimalista, silhouette piccoli uccelli che fluiscono verso l'alto, composizione bilanciata, contorni taglienti, inchiostro nero alto contrasto, realismo tatuaggio moderno, solo monocromatico, nessuno sfondo su tela bianca, flash professionale, pronto per stencil.",
  "@explorePromptFeatherAndBirdsInFlight": { "description": "Home: Explore item prompt - Feather and birds in flight" },

  "exploreTitleRainyBatWithCelestialStars": "Pipistrello piovoso con stelle celestiali",
  "@exploreTitleRainyBatWithCelestialStars": { "description": "Home: Explore item title - Rainy bat with celestial stars" },
