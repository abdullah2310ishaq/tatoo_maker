  "exploreCategoryMinimal": "Tatuaggi minimalisti",
  "exploreCategoryMinimalDescription": "Linee semplici e pulite con estetica minimalista. Perfetti per design sottili ed eleganti.",
  "exploreCategoryTraditional": "Tradizionale e Old School",
