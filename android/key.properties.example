## Example signing config (DO NOT COMMIT real secrets)
##
## Copy this file to `android/key.properties` and fill values when you create your real JKS.
##
## storeFile can be relative to the `android/` folder, e.g.:
## storeFile=../keystores/release.jks
storeFile=path/to/release.jks
storePassword=YOUR_STORE_PASSWORD
keyAlias=YOUR_KEY_ALIAS
keyPassword=YOUR_KEY_PASSWORD
